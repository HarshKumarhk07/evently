# Base URL of the Bookify API. Leave as /api to use the Vite dev proxy.
VITE_API_URL=/api

# Razorpay key id (optional — checkout runs in mock mode when blank).
VITE_RAZORPAY_KEY_ID=

# Firebase web SDK (optional — "Continue with Google" hides if blank).
# Copy these from: Firebase Console → Project Settings → "Your apps" → Web app.
VITE_FIREBASE_API_KEY=
VITE_FIREBASE_AUTH_DOMAIN=
VITE_FIREBASE_PROJECT_ID=
VITE_FIREBASE_STORAGE_BUCKET=
VITE_FIREBASE_MESSAGING_SENDER_ID=
VITE_FIREBASE_APP_ID=
