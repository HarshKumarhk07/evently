# ─── Server ───────────────────────────────────────────────
NODE_ENV=development
PORT=5000
CLIENT_URL=http://localhost:5173

# ─── Database ─────────────────────────────────────────────
MONGO_URI=mongodb://127.0.0.1:27017/bookify

# ─── Auth ─────────────────────────────────────────────────
JWT_SECRET=replace_with_a_long_random_secret_string
JWT_EXPIRES_IN=7d

# ─── Cloudinary (optional — image uploads) ────────────────
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=

# ─── Razorpay (optional — falls back to mock mode if blank) ─
RAZORPAY_KEY_ID=
RAZORPAY_KEY_SECRET=

# ─── Email / Brevo (optional — logs to console if blank) ───
BREVO_API_KEY=
BREVO_SENDER_EMAIL=no-reply@bookify.app
BREVO_SENDER_NAME=Bookify

# ─── Firebase Admin (optional — Google sign-in verification) ─
# From: Firebase Console → Project Settings → Service Accounts → "Generate new private key"
# FIREBASE_PRIVATE_KEY must be the full PEM string. Wrap it in quotes and keep
# the literal "\n" sequences — env.js converts them back to real newlines.
FIREBASE_PROJECT_ID=
FIREBASE_CLIENT_EMAIL=
FIREBASE_PRIVATE_KEY=
